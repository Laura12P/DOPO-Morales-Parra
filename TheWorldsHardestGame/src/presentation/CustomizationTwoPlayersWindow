package presentation;

import javax.swing.*;
import java.awt.*;

public class CustomizationTwoPlayersWindow extends JFrame {

    private Color selectedColorP1 = Color.RED;
    private Color selectedColorP2 = Color.RED;

    public CustomizationTwoPlayersWindow() {
        setTitle("Personalizacion de Dos Personajes");
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setSize(920, 520);
        setLocationRelativeTo(null);
        setResizable(false);

        JPanel mainPanel = new JPanel(new BorderLayout());
        mainPanel.setBackground(Color.WHITE);

        // Barra superior
        JLabel topBar = new JLabel("The World Hardest Game");
        topBar.setBackground(new Color(220, 220, 220));
        topBar.setOpaque(true);
        topBar.setBorder(BorderFactory.createEmptyBorder(8, 10, 8, 10));
        mainPanel.add(topBar, BorderLayout.NORTH);

        // Panel central dividido en dos
        JPanel centerPanel = new JPanel(new GridLayout(1, 2));
        centerPanel.setBackground(Color.WHITE);
        centerPanel.add(buildPlayerPanel("Player One", "WASD", 1));
        centerPanel.add(buildPlayerPanel("Player Two", "Up, Down,\nLeft, Right", 2));
        mainPanel.add(centerPanel, BorderLayout.CENTER);

        // Botones Back y Continue
        JPanel bottomPanel = new JPanel(new BorderLayout());
        bottomPanel.setBackground(Color.WHITE);
        bottomPanel.setBorder(BorderFactory.createEmptyBorder(10, 60, 20, 60));

        JButton btnBack = new JButton("Back");
        btnBack.setPreferredSize(new Dimension(120, 40));
        btnBack.setFocusPainted(false);
        btnBack.setFont(new Font("Arial", Font.PLAIN, 16));

        JButton btnContinue = new JButton("Continue");
        btnContinue.setPreferredSize(new Dimension(120, 40));
        btnContinue.setFocusPainted(false);
        btnContinue.setFont(new Font("Arial", Font.PLAIN, 16));

        bottomPanel.add(btnBack, BorderLayout.WEST);
        bottomPanel.add(btnContinue, BorderLayout.EAST);
        mainPanel.add(bottomPanel, BorderLayout.SOUTH);

        btnBack.addActionListener(e -> {
            dispose();
            new GameModeWindow(getWidth(), getHeight()).setVisible(true);
        });

        btnContinue.addActionListener(e -> {
            // TODO: abrir ventana del juego
            JOptionPane.showMessageDialog(this, "Iniciando Player vs Player");
        });

        add(mainPanel);
    }

    private JPanel buildPlayerPanel(String playerTitle, String controls, int player) {
        JPanel panel = new JPanel();
        panel.setLayout(new BoxLayout(panel, BoxLayout.Y_AXIS));
        panel.setBackground(Color.WHITE);
        panel.setBorder(BorderFactory.createEmptyBorder(20, 30, 10, 30));

        // Título
        JLabel title = new JLabel(playerTitle, SwingConstants.CENTER);
        title.setFont(new Font("Arial", Font.PLAIN, 22));
        title.setAlignmentX(Component.CENTER_ALIGNMENT);
        panel.add(title);
        panel.add(Box.createVerticalStrut(15));

        // Colores
        JPanel colorsRow = new JPanel(new FlowLayout(FlowLayout.CENTER, 10, 0));
        colorsRow.setBackground(Color.WHITE);

        Color[] colors = {Color.RED, Color.BLUE, Color.GREEN};
        for (Color color : colors) {
            JPanel colorBox = new JPanel();
            colorBox.setBackground(color);
            colorBox.setPreferredSize(new Dimension(70, 70));
            colorBox.setBorder(BorderFactory.createLineBorder(Color.BLACK, 3));
            colorBox.setCursor(new Cursor(Cursor.HAND_CURSOR));
            colorBox.addMouseListener(new java.awt.event.MouseAdapter() {
                public void mouseClicked(java.awt.event.MouseEvent e) {
                    for (Component c : colorsRow.getComponents()) {
                        ((JPanel) c).setBorder(BorderFactory.createLineBorder(Color.BLACK, 3));
                    }
                    colorBox.setBorder(BorderFactory.createLineBorder(Color.BLACK, 6));
                    if (player == 1) selectedColorP1 = color;
                    else selectedColorP2 = color;
                }
            });
            colorsRow.add(colorBox);
        }
        panel.add(colorsRow);
        panel.add(Box.createVerticalStrut(15));

        // Nombre
        JPanel namePanel = new JPanel(new FlowLayout(FlowLayout.LEFT));
        namePanel.setBackground(Color.WHITE);
        JLabel nameLabel = new JLabel("Name:");
        nameLabel.setFont(new Font("Arial", Font.PLAIN, 16));
        JTextField nameField = new JTextField(10);
        namePanel.add(nameLabel);
        namePanel.add(nameField);
        panel.add(namePanel);
        panel.add(Box.createVerticalStrut(10));

        // Controles
        JLabel controlsLabel = new JLabel("<html>Controls: " + controls.replace("\n", "<br>") + "</html>");
        controlsLabel.setFont(new Font("Arial", Font.PLAIN, 14));
        controlsLabel.setBorder(BorderFactory.createEmptyBorder(0, 10, 0, 0));
        panel.add(controlsLabel);

        return panel;
    }
}
